const modules = [
  { n: 1, slug: "session-flow", title: "The session flow",            tag: "foundations" },
  { n: 2, slug: "identity",     title: "Identity files: SOUL, MEMORY, USER", tag: "context"     },
  { n: 3, slug: "tools",        title: "Tools, plugins, MCP",         tag: "extension"   },
  { n: 4, slug: "hooks",        title: "Hooks lifecycle",             tag: "extension"   },
  { n: 5, slug: "peers",        title: "Peers and memory providers",  tag: "memory"      },
  { n: 6, slug: "coordination", title: "Profiles, sub-agents, Kanban",tag: "scale"       },
];
