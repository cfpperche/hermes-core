        font-size: 10px;
        fill: var(--color-fg-dim);
      }
      .svg-actual-sub-box {
        fill: var(--color-surface-mid);
        stroke: var(--color-amber);
      }
      .svg-actual-sub-box-t {
        font-family: var(--font-mono);
        font-size: 11px;
        fill: var(--color-amber);
      }

      /* Schema diagram (Fig 5) */
      .svg-table {
        fill: var(--color-bg);
        stroke: var(--color-bronze);
      }
      .svg-table-small { fill: var(--color-surface-mid); }
      .svg-table-virt { stroke: var(--color-teal); }
      .svg-table-h {
        fill: var(--color-surface);
        stroke: var(--color-bronze);
      }
      .svg-table-h-t {
        font-family: var(--font-mono);
        font-size: 13px;
        font-weight: 700;
        fill: var(--color-gold);
      }
      .svg-table-h-t-virt {
        font-family: var(--font-mono);
        font-size: 13px;
        font-weight: 700;
        fill: var(--color-teal);
      }
      .svg-table-col {
        font-family: var(--font-mono);
        font-size: 11px;
        fill: var(--color-fg);
      }
      .svg-table-col-dim {
        font-family: var(--font-mono);
        font-size: 10px;
        fill: var(--color-fg-dim);
        font-style: italic;
      }
      .svg-fk-arrow {
        fill: none;
        stroke: var(--color-amber);
        stroke-width: 1.5;
      }
      .svg-fk-label {
        font-family: var(--font-mono);
        font-size: 10.5px;
        fill: var(--color-amber);
        font-weight: 700;
      }
      .svg-fk-label-dim {
        font-family: var(--font-mono);
        font-size: 9.5px;
        fill: var(--color-fg-dim);
      }

      /* Wrap-up section */
      .in-wrap {
        background: var(--color-surface);
        border: 1px solid var(--color-bronze);
        border-left: 4px solid var(--color-gold);
        padding: 1.5rem 1.65rem 1.25rem;
        margin-top: 2rem;
        margin-bottom: 2.5rem;
      }
      .in-wrap-list {
        margin: 0 0 1.25rem;
        padding-left: 1.4rem;
        line-height: 1.65;
      }
      .in-wrap-list li {
        margin-bottom: 0.6rem;
        font-size: 0.93rem;
        color: var(--color-fg);
      }
      .in-wrap-list code {
        background: var(--color-bg);
        color: var(--color-amber);
        padding: 0.05rem 0.3rem;
        font-size: 0.85em;
      }
      .in-wrap-list b { color: var(--color-gold); }
      .in-wrap-foot {
        font-size: 0.85rem;
        color: var(--color-fg-dim);
        font-style: italic;
        line-height: 1.6;
        margin: 0;
      }
      .in-wrap-foot a {
        color: var(--color-amber);
        border-bottom: 1px dotted var(--color-amber);
      }

      @media print {
        :root {
          --color-bg: #ffffff;
          --color-surface: #f7f7f5;
          --color-surface-mid: #efefea;
          --color-fg: #111111;
          --color-fg-dim: #555555;
          --color-bronze: #555555;
        }
        .hc-top, .hc-foot { display: none; }
        .in-svg { background: #ffffff; }
        .in-mod { break-inside: avoid; }
        .in-fig { break-inside: avoid; }
      }
    </style>

    <script is:inline>
      (() => {
        const pdf = document.getElementById("hc-pdf");
        if (pdf) pdf.addEventListener("click", () => window.print());
      })();
    </script>
  </body>
</html>
