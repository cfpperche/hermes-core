            <text x="460" y="156" class="svg-actual-sub-box-t" text-anchor="middle">plugin cbs</text>
            <rect x="540" y="130" width="120" height="44" class="svg-actual-sub-box"/>
            <text x="600" y="156" class="svg-actual-sub-box-t" text-anchor="middle">shell-hook closures</text>

            <!-- Dispatcher 2: Gateway HookRegistry -->
            <rect x="380" y="210" width="300" height="64" class="svg-actual-box"/>
            <text x="400" y="234" class="svg-actual-h">gateway/hooks.HookRegistry</text>
            <text x="400" y="254" class="svg-actual-sub">separate process · emit / emit_collect</text>

            <!-- Ambient table -->
            <rect x="380" y="290" width="300" height="54" class="svg-actual-box svg-actual-box-dim"/>
            <text x="400" y="314" class="svg-actual-h-dim">tool_guardrails.py</text>
